%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#232F3E', 'primaryTextColor': '#fff', 'primaryBorderColor': '#FF9900', 'lineColor': '#FF9900', 'secondaryColor': '#f0f0f0', 'tertiaryColor': '#e8e8e8', 'fontSize': '14px'}}}%%

graph TB
    subgraph SOURCES["<b>Data Sources</b>"]
        direction TB
        RDS["🗄️ Amazon RDS MySQL<br/><i>Core Banking Members</i><br/>(2,000 records)"]
        CSV["📄 CSV Files<br/><i>Digital Banking &<br/>Loan System</i>"]
        XML["📋 XML Files<br/><i>CRM System &<br/>Credit Cards</i>"]
    end

    subgraph INFRA["<b>Infrastructure Layer</b> — CDK Stack 1"]
        direction TB
        VPC["🔒 Amazon VPC<br/><i>Private Subnets, NAT Gateway,<br/>VPC Endpoints (S3, Secrets Manager)</i>"]
        KMS["🔑 AWS KMS<br/><i>Customer-Managed Key<br/>with Auto-Rotation</i>"]
        SM["🔐 AWS Secrets Manager<br/><i>RDS Credentials</i>"]
        IAM["👤 AWS IAM<br/><i>Least-Privilege Roles</i>"]
    end

    subgraph COLLECT["<b>Collect Zone</b> — S3 (Raw)"]
        S3C["📦 Amazon S3<br/><i>creditunion-*-collect</i><br/>KMS Encrypted"]
    end

    subgraph CATALOG["<b>Data Catalog Layer</b> — CDK Stack 2"]
        direction TB
        GLUEDB["📚 AWS Glue Data Catalog<br/><i>3 Databases: cleanse,<br/>consume, xml_catalog</i>"]
        CONN["🔗 Glue JDBC Connection<br/><i>MySQL via Private Subnet</i>"]
        CRAWL["🕷️ Glue Crawlers<br/><i>CRM XML & Credit Cards XML</i>"]
    end

    subgraph ETL["<b>ETL Layer</b> — CDK Stack 3"]
        direction TB
        SF["⚙️ AWS Step Functions<br/><i>ETL Orchestration</i>"]
        subgraph JOBS["Glue Visual ETL Jobs (Parallel)"]
            J1["Job 1: MySQL ETL<br/><i>RDS → Parquet</i>"]
            J2["Job 2: XML ETL<br/><i>XML → Parquet</i>"]
            J3["Job 3: CSV ETL<br/><i>CSV → Parquet</i>"]
        end
        J4["Job 4: Member 360<br/><i>Entity Resolution &<br/>Multi-Source Join</i>"]
    end

    subgraph CLEANSE["<b>Cleanse Zone</b> — S3 (Processed)"]
        S3CL["📦 Amazon S3<br/><i>creditunion-*-cleanse</i><br/>Snappy Parquet, Partitioned"]
    end

    subgraph CONSUME["<b>Consume Zone</b> — S3 (Analytics-Ready)"]
        S3CO["📦 Amazon S3<br/><i>creditunion-*-consume</i><br/>Member 360 Profiles"]
    end

    subgraph AUTOMATION["<b>Automation Layer</b> — CDK Stack 4"]
        direction TB
        TRIG["⚡ AWS CloudFormation<br/>Custom Resources<br/><i>Auto-Trigger Pipeline</i>"]
        LF1["λ Lambda: RDS Loader<br/><i>Python 3.13 + PyMySQL</i>"]
        LF2["λ Lambda: Crawler Trigger"]
        LF3["λ Lambda: Crawler Wait<br/><i>Smart Polling</i>"]
    end

    subgraph ANALYTICS["<b>Analytics & BI</b>"]
        ATH["🔍 Amazon Athena<br/><i>SQL Analytics</i>"]
        QS["📊 Amazon QuickSight<br/><i>Dashboards & BI</i>"]
    end

    %% Data Flow
    RDS --> LF1
    LF1 --> |"Load 2K records"| RDS
    CSV --> S3C
    XML --> S3C

    S3C --> CRAWL
    CRAWL --> GLUEDB

    TRIG --> LF1
    TRIG --> LF2
    LF2 --> CRAWL
    LF3 --> |"Poll until ready"| CRAWL
    TRIG --> SF

    SF --> J1
    SF --> J2
    SF --> J3

    RDS -.-> |"JDBC via VPC"| J1
    S3C --> J2
    S3C --> J3

    J1 --> S3CL
    J2 --> S3CL
    J3 --> S3CL

    S3CL --> J4
    J4 --> S3CO

    S3CO --> ATH
    S3CO --> QS

    %% Security overlay
    KMS -.-> |"Encrypts"| S3C
    KMS -.-> |"Encrypts"| S3CL
    KMS -.-> |"Encrypts"| S3CO
    KMS -.-> |"Encrypts"| RDS
    SM -.-> |"Credentials"| LF1
    SM -.-> |"Credentials"| CONN

    classDef sourceStyle fill:#1B660F,stroke:#fff,color:#fff,stroke-width:1px
    classDef infraStyle fill:#232F3E,stroke:#FF9900,color:#fff,stroke-width:2px
    classDef s3Style fill:#3F8624,stroke:#fff,color:#fff,stroke-width:1px
    classDef catalogStyle fill:#8C4FFF,stroke:#fff,color:#fff,stroke-width:1px
    classDef etlStyle fill:#C7511F,stroke:#fff,color:#fff,stroke-width:1px
    classDef autoStyle fill:#DD344C,stroke:#fff,color:#fff,stroke-width:1px
    classDef analyticsStyle fill:#0073BB,stroke:#fff,color:#fff,stroke-width:1px

    class RDS,CSV,XML sourceStyle
    class VPC,KMS,SM,IAM infraStyle
    class S3C,S3CL,S3CO s3Style
    class GLUEDB,CONN,CRAWL catalogStyle
    class SF,J1,J2,J3,J4 etlStyle
    class TRIG,LF1,LF2,LF3 autoStyle
    class ATH,QS analyticsStyle
